// CasaWallet — Prisma schema
// DB: PostgreSQL (Railway)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Famiglia: l'unità di tenancy. Tutti i dati (transazioni, scontrini, budget,
// lista spesa) sono condivisi tra i membri; il salvadanaio tasse resta personale.
model Household {
  id         String   @id @default(cuid())
  name       String
  inviteCode String   @unique // codice condivisibile per far entrare un nuovo membro
  createdAt  DateTime @default(now())

  users             User[]
  transactions      Transaction[]
  receipts          Receipt[]
  recurringProducts RecurringProduct[]
  dismissals        ShoppingListDismissal[]
  categoryBudgets   CategoryBudget[]
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String
  passwordHash String
  householdId  String
  household    Household     @relation(fields: [householdId], references: [id])
  role         String        @default("MEMBER") // OWNER | MEMBER — validato in API (niente enum: dual-provider)
  createdAt    DateTime      @default(now())
  transactions Transaction[]
  receipts     Receipt[]
  pushSubscriptions PushSubscription[]
}

model Transaction {
  id          String      @id @default(cuid())
  userId      String      // chi l'ha creata (attribuzione)
  user        User        @relation(fields: [userId], references: [id])
  householdId String      // denormalizzato per le query di famiglia
  household   Household   @relation(fields: [householdId], references: [id])
  amount      Float
  type        TxType
  category    String
  subcategory String?
  method      PayMethod
  description String?
  date        DateTime
  taxPercent  Float?
  taxAmount   Float?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  taxSaving   TaxSaving?
  receipt     Receipt?

  @@index([householdId, date])
}

model TaxSaving {
  id            String       @id @default(cuid())
  transactionId String       @unique
  transaction   Transaction  @relation(fields: [transactionId], references: [id])
  amount        Float
  month         Int
  year          Int
  transferred   Boolean      @default(false)
  transferredAt DateTime?
}

enum TxType {
  INCOME
  EXPENSE
}

enum PayMethod {
  CASH
  POS
  CARD
  TRANSFER
}

model Receipt {
  id            String        @id @default(cuid())
  userId        String        // chi l'ha caricato
  user          User          @relation(fields: [userId], references: [id])
  householdId   String        // denormalizzato per le query di famiglia
  household     Household     @relation(fields: [householdId], references: [id])
  store         String?
  total         Float
  date          DateTime
  transactionId String?       @unique
  transaction   Transaction?  @relation(fields: [transactionId], references: [id])
  items         ReceiptItem[]
  createdAt     DateTime      @default(now())

  @@index([householdId, date])
}

model ReceiptItem {
  id            String   @id @default(cuid())
  receiptId     String
  receipt       Receipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  rawName       String   // nome come appare sullo scontrino
  canonicalName String   // nome normalizzato per il raggruppamento nel tempo
  category      String   // categoria da lista fissa (vedi ALLOWED_CATEGORIES nel backend)
  quantity      Float    @default(1)
  unitPrice     Float?
  totalPrice    Float
  store         String?
  date          DateTime
  createdAt     DateTime @default(now())
}

model RecurringProduct {
  id            String    @id @default(cuid())
  householdId   String
  household     Household @relation(fields: [householdId], references: [id])
  canonicalName String
  intervalDays  Int?      // se impostato manualmente, override del calcolo automatico
  alwaysBuy     Boolean   @default(false) // "ricorrente fisso": in lista anche con pochi dati
  createdAt     DateTime  @default(now())

  @@unique([householdId, canonicalName])
}

model ShoppingListDismissal {
  id            String    @id @default(cuid())
  householdId   String
  household     Household @relation(fields: [householdId], references: [id])
  canonicalName String
  dismissedAt   DateTime  @default(now())

  @@unique([householdId, canonicalName])
}

// Budget mensile per categoria di spesa (uno per famiglia+categoria). La spesa
// effettiva del mese corrente viene calcolata a runtime dalle transazioni.
model CategoryBudget {
  id          String    @id @default(cuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id])
  category    String
  amount      Float
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([householdId, category])
}

// Web Push (VAPID) subscription per device/browser. One user can have several.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}
