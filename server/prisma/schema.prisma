// CasaWallet — Prisma schema
// DB: PostgreSQL (Railway)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Famiglia: l'unità di tenancy. Tutti i dati (transazioni, scontrini, budget,
// lista spesa) sono condivisi tra i membri; il salvadanaio tasse resta personale.
model Household {
  id         String   @id @default(cuid())
  name       String
  inviteCode String   @unique // codice condivisibile per far entrare un nuovo membro
  createdAt  DateTime @default(now())

  users             User[]
  transactions      Transaction[]
  receipts          Receipt[]
  recurringProducts RecurringProduct[]
  dismissals        ShoppingListDismissal[]
  categoryBudgets   CategoryBudget[]
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String
  passwordHash String
  householdId  String
  household    Household     @relation(fields: [householdId], references: [id])
  role         String        @default("MEMBER") // OWNER | MEMBER — validato in API (niente enum: dual-provider)
  createdAt    DateTime      @default(now())
  transactions Transaction[]
  receipts     Receipt[]
  pushSubscriptions PushSubscription[]
  taxDeadlines  TaxDeadline[]
  fiscalProfile FiscalProfile?
  invoices        Invoice[]
  arubaConnection ArubaConnection?
}

model Transaction {
  id          String      @id @default(cuid())
  userId      String      // chi l'ha creata (attribuzione)
  user        User        @relation(fields: [userId], references: [id])
  householdId String      // denormalizzato per le query di famiglia
  household   Household   @relation(fields: [householdId], references: [id])
  amount      Float
  type        TxType
  category    String
  subcategory String?
  method      PayMethod
  description String?
  date        DateTime
  taxPercent  Float?
  taxAmount   Float?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  taxSaving   TaxSaving?
  receipt     Receipt?
  invoice     Invoice?

  @@index([householdId, date])
}

model TaxSaving {
  id            String       @id @default(cuid())
  transactionId String       @unique
  transaction   Transaction  @relation(fields: [transactionId], references: [id])
  amount        Float
  month         Int
  year          Int
  transferred   Boolean      @default(false)
  transferredAt DateTime?
}

enum TxType {
  INCOME
  EXPENSE
}

enum PayMethod {
  CASH
  POS
  CARD
  TRANSFER
}

model Receipt {
  id            String        @id @default(cuid())
  userId        String        // chi l'ha caricato
  user          User          @relation(fields: [userId], references: [id])
  householdId   String        // denormalizzato per le query di famiglia
  household     Household     @relation(fields: [householdId], references: [id])
  store         String?
  total         Float
  date          DateTime
  transactionId String?       @unique
  transaction   Transaction?  @relation(fields: [transactionId], references: [id])
  items         ReceiptItem[]
  createdAt     DateTime      @default(now())

  @@index([householdId, date])
}

model ReceiptItem {
  id            String   @id @default(cuid())
  receiptId     String
  receipt       Receipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  rawName       String   // nome come appare sullo scontrino
  canonicalName String   // nome normalizzato per il raggruppamento nel tempo
  category      String   // categoria da lista fissa (vedi ALLOWED_CATEGORIES nel backend)
  quantity      Float    @default(1)
  unitPrice     Float?
  totalPrice    Float
  store         String?
  date          DateTime
  createdAt     DateTime @default(now())

  // Le analytics raggruppano/filtrano per canonicalName e joinano su receiptId.
  @@index([receiptId])
  @@index([canonicalName])
}

model RecurringProduct {
  id            String    @id @default(cuid())
  householdId   String
  household     Household @relation(fields: [householdId], references: [id])
  canonicalName String
  intervalDays  Int?      // se impostato manualmente, override del calcolo automatico
  alwaysBuy     Boolean   @default(false) // "ricorrente fisso": in lista anche con pochi dati
  createdAt     DateTime  @default(now())

  @@unique([householdId, canonicalName])
}

model ShoppingListDismissal {
  id            String    @id @default(cuid())
  householdId   String
  household     Household @relation(fields: [householdId], references: [id])
  canonicalName String
  dismissedAt   DateTime  @default(now())

  @@unique([householdId, canonicalName])
}

// Budget mensile per categoria di spesa (uno per famiglia+categoria). La spesa
// effettiva del mese corrente viene calcolata a runtime dalle transazioni.
model CategoryBudget {
  id          String    @id @default(cuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id])
  category    String
  amount      Float
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([householdId, category])
}

// Web Push (VAPID) subscription per device/browser. One user can have several.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

// Scadenza fiscale PERSONALE (le tasse sono per-utente, come il salvadanaio).
model TaxDeadline {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  name           String    // es. "Saldo IRPEF 2025"
  type           String    // IRPEF_SALDO | IRPEF_ACCONTO | IVA | INPS | ALTRO — validato in API (dual-provider)
  dueDate        DateTime
  expectedAmount Float
  paid           Boolean   @default(false)
  paidAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId, dueDate])
}

// Profilo fiscale PERSONALE (1:1 con User). Stima, non consulenza fiscale.
model FiscalProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id])
  regime            String   @default("FORFETTARIO") // FORFETTARIO | ORDINARIO | ALTRO — validato in API
  partitaIva        String?  // P.IVA dell'utente: verifica proprietà delle fatture importate
  coeffRedditivita  Float?   // es. 0.78 (forfettario)
  aliquotaImposta   Float?   // es. 15 (%)
  aliquotaInps      Float?   // es. 26.23 (%)
  defaultTaxPercent Float?   // % prefill nel form entrate (scelta libera dell'utente)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Fattura elettronica emessa (PERSONALE, come TaxDeadline). L'entrata nel
// bilancio si crea SOLO al momento dell'incasso (regime di cassa).
// status: EMESSA | INCASSATA — source: XML | ARUBA (validati in API)
model Invoice {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  source        String       // "XML" | "ARUBA"
  filename      String?      // nome file caricato / filename Aruba (informativo)
  numero        String
  year          Int          // anno della Data documento (chiave dedupe + filtro)
  date          DateTime
  tipoDocumento String       @default("TD01")
  customerName  String
  customerVat   String?
  imponibile    Float        // Σ DatiRiepilogo.ImponibileImporto (include cassa)
  iva           Float        // Σ DatiRiepilogo.Imposta
  ritenuta      Float        // Σ DatiRitenuta.ImportoRitenuta
  cassa         Float        // Σ DatiCassaPrevidenziale.ImportoContributoCassa (informativo)
  bollo         Float        // DatiBollo.ImportoBollo || 0
  grossTotal    Float        // imponibile + iva + bollo
  netToPay      Float        // grossTotal - ritenuta → importo dell'entrata all'incasso
  dueDate       DateTime?    // prima DataScadenzaPagamento (se presente)
  sdiStatus     String?      // solo Aruba: Inviata | Consegnata | Non consegnata
  warning       String?      // es. PAGAMENTI_NON_COINCIDONO, TOTALE_DOCUMENTO_DIVERSO
  status        String       @default("EMESSA") // EMESSA | INCASSATA
  collectedAt   DateTime?
  transactionId String?      @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([userId, numero, year])
  @@index([userId, date])
}

// Connessione Aruba Fatturazione Elettronica (credenziali cifrate AES-256-GCM,
// chiave da env INVOICE_CRED_SECRET — mai in chiaro, mai nelle response).
model ArubaConnection {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id])
  username          String
  encryptedPassword String    // formato iv:tag:ciphertext (base64)
  lastSyncAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}
